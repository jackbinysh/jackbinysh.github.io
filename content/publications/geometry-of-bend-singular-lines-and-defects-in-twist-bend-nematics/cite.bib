@article{binyshGeometryBendSingular2020,
  abstract = {We describe the geometry of bend distortions in liquid crystals and their fundamental degeneracies, which we call {$\beta$} lines; these represent a new class of linelike topological defect in twist-bend nematics. We present constructions for smecticlike textures containing screw and edge dislocations and also for vortexlike structures of double twist and Skyrmions. We analyze their local geometry and global structure, showing that their intersection with any surface is twice the Skyrmion number. Finally, we demonstrate how arbitrary knots and links can be created and describe them in terms of merons, giving a geometric perspective on the fractionalization of Skyrmions.},
  author = {Binysh, Jack and Pollard, Joseph and Alexander, Gareth P.},
  doi = {10.1103/PhysRevLett.125.047801},
  file = {/Users/jackbinysh/Zotero/storage/H9QRJ293/Binysh et al. - 2020 - Geometry of Bend Singular Lines and Defects in Tw.pdf},
  journal = {Physical Review Letters},
  month = {July},
  number = {4},
  pages = {047801},
  publisher = {American Physical Society},
  shorttitle = {Geometry of {{Bend}}},
  title = {Geometry of {{Bend}}: {{Singular Lines}} and {{Defects}} in {{Twist-Bend Nematics}}},
  urldate = {2022-02-21},
  volume = {125},
  year = {2020}
}

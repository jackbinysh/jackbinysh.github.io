@article{binyshThreeDimensionalActiveDefect2020,
  title = {Three-{{Dimensional Active Defect Loops}}},
  author = {Binysh, Jack and Kos, {\v Z}iga and {\v C}opar, Simon and Ravnik, Miha and Alexander, Gareth P.},
